# Paystack Public Key for Lumina payment checkout flow
VITE_PAYSTACK_PUBLIC_KEY=

# Paystack Secret Key for secure backend verification
PAYSTACK_SECRET_KEY=

# Optionals: Paystack Plan codes created in your Paystack dashboard to link custom pricing tiers
VITE_PAYSTACK_PLAN_MONTHLY=
VITE_PAYSTACK_PLAN_6MONTH=

# Public App URL (e.g. https://your-lumina-domain.com or your public shared URL)
# Used to bypass Google-auth-protected developer preview URLs inside QR codes and shared invitation links
VITE_PUBLIC_APP_URL=

# Fallback Merchant/Partner bank details for simulated or manual checkouts
VITE_MANUAL_TRANSFER_BANK=
VITE_MANUAL_TRANSFER_ACCOUNT=
VITE_MANUAL_TRANSFER_NAME=

